   {                                                                                                               
     "name": "PiSense Agent",                                                                                      
     "image": "mcr.microsoft.com/devcontainers/typescript-node:4-24-trixie",                                       
     "features": {                                                                                                 
       "ghcr.io/shyim/devcontainers-features/bun:0": {}                                                            
     },                                                                                                            
     "forwardPorts": [3000, 8086],                                                                           
     "runArgs": ["-p", "1883:1883", "-p", "3000:3000", "-p", "8086:8086"],                                         
     "portsAttributes": {                                                                                          
       "1883": {                                                                                                   
         "label": "MQTT (Mosquitto)",                                                                              
         "onAutoForward": "notify"                                                                                 
       },                                                                                                          
       "3000": {                                                                                                   
         "label": "PiSense Dashboard",                                                                             
         "onAutoForward": "openBrowser"                                                                            
       },                                                                                                          
       "8086": {                                                                                                   
         "label": "InfluxDB",                                                                                      
         "onAutoForward": "silent"                                                                                 
       }                                                                                                           
     },                                                                                                            
     "remoteUser": "root"                                                                                          
   } 