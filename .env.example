# ── Dashboard ──
PORT=3000

# ── InfluxDB ──
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influxdb-token-here
INFLUX_ORG=pisense
INFLUX_BUCKET=sensors

# ── InfluxDB Setup (first-run only) ──
INFLUX_ADMIN_USERNAME=admin
INFLUX_ADMIN_PASSWORD=your-admin-password-here
INFLUX_SETUP_TOKEN=your-setup-token-here

# ── MQTT (Mosquitto) ──
MQTT_BROKER=tcp://localhost:1883
