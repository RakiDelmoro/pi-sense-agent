# ── Dashboard ──
PORT=3000

# ── InfluxDB ──
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=pisense-default-token
INFLUX_ORG=pisense
INFLUX_BUCKET=sensors

# ── InfluxDB Setup (first-run only, used by Docker image) ──
INFLUX_ADMIN_USERNAME=admin
INFLUX_ADMIN_PASSWORD=pisense-default-password

# ── MQTT (Mosquitto) ──
MQTT_BROKER=mqtt://mosquitto:1883

# ── AI Provider (for Pi) ──
# Uncomment the one you use and paste your key
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
